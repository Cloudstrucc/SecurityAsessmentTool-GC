<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{#if title}}{{title}}{{else}}Vanguard Cloud Services — SA&A Platform{{/if}}</title>
  <meta name="description" content="Vanguard Cloud Services — Security Assessment & Authorization — Multi-Framework Compliance Platform">
  <meta name="theme-color" content="#0a0e17">

  <link rel="preconnect" href="https://fonts.googleapis.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --c-bg: #0a0e17;
      --c-surface: #111827;
      --c-surface-2: #1a2235;
      --c-border: #2a3550;
      --c-border-hover: #3b4f73;
      --c-text: #e2e8f0;
      --c-text-muted: #8896b0;
      --c-text-dim: #5a6a85;
      --c-brand: #38bdf8;
      --c-brand-glow: rgba(56,189,248,.15);
      --c-accent: #818cf8;
      --c-success: #34d399;
      --c-danger: #f87171;
      --font: 'DM Sans', -apple-system, sans-serif;
      --mono: 'JetBrains Mono', monospace;
    }
    html { scroll-behavior: smooth; }
    body {
      font-family: var(--font); background: var(--c-bg); color: var(--c-text);
      line-height: 1.65; -webkit-font-smoothing: antialiased; min-height: 100vh;
    }
    a { color: var(--c-brand); text-decoration: none; }
    a:hover { color: #7dd3fc; }

    /* Grain overlay */
    body::before {
      content: ''; position: fixed; inset: 0; z-index: 0; pointer-events: none; opacity: .025;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
    }
    body > * { position: relative; z-index: 1; }

    /* ── Minimal nav ── */
    .min-nav {
      padding: 1rem 2rem;
      display: flex; align-items: center; justify-content: space-between;
      border-bottom: 1px solid var(--c-border);
      background: rgba(10,14,23,.85); backdrop-filter: blur(20px);
      position: sticky; top: 0; z-index: 100;
    }
    .min-nav .logo { display: flex; align-items: center; gap: .6rem; text-decoration: none; }
    .min-nav .logo-mark {
      width: 34px; height: 34px; border-radius: 9px;
      background: linear-gradient(135deg, var(--c-brand) 0%, var(--c-accent) 100%);
      display: flex; align-items: center; justify-content: center;
      font-size: 1rem; color: #fff; box-shadow: 0 0 18px var(--c-brand-glow);
    }
    .min-nav .logo-text { font-weight: 700; font-size: 1rem; color: var(--c-text); }
    .min-nav .logo-text span { font-weight: 400; color: var(--c-text-muted); }
    .min-nav .nav-right { display: flex; align-items: center; gap: .5rem; }
    .min-nav .nav-link {
      padding: .45rem 1rem; border-radius: 8px; font-size: .875rem; font-weight: 500;
      color: var(--c-text-muted); transition: all .2s; text-decoration: none;
    }
    .min-nav .nav-link:hover { color: var(--c-text); background: var(--c-surface); }
    .min-nav .nav-link.login-btn {
      background: var(--c-surface); border: 1px solid var(--c-border); color: var(--c-text);
    }
    .min-nav .nav-link.login-btn:hover { border-color: var(--c-brand); color: var(--c-brand); }

    /* ── Flash messages ── */
    .flash-wrap { max-width: 600px; margin: 1rem auto; padding: 0 1rem; }

    /* ── Footer ── */
    .min-footer {
      text-align: center; padding: 2rem; color: var(--c-text-dim); font-size: .75rem;
      border-top: 1px solid var(--c-border); margin-top: 2rem;
    }
  </style>
</head>
<body>

  <nav class="min-nav">
    <a href="/" class="logo">
      <span class="logo-mark"><i class="bi bi-shield-lock-fill"></i></span>
      <span class="logo-text">Vanguard Cloud Services <span>Inc.</span></span>
    </a>
    <div class="nav-right">
      <a href="/portal" class="nav-link login-btn">
        <i class="bi bi-box-arrow-in-right me-1"></i>Sign In
      </a>
    </div>
  </nav>

  {{#if messages.error}}<div class="flash-wrap"><div class="alert alert-danger alert-dismissible fade show py-2 small"><i class="bi bi-exclamation-circle me-1"></i>{{messages.error}}<button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert"></button></div></div>{{/if}}
  {{#if messages.success}}<div class="flash-wrap"><div class="alert alert-success alert-dismissible fade show py-2 small"><i class="bi bi-check-circle me-1"></i>{{messages.success}}<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div></div>{{/if}}

  {{{body}}}

  <footer class="min-footer">
    &copy; {{currentYear}} Vanguard Cloud Services Inc. &mdash; Security Assessment & Authorization Platform
  </footer>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
