<div class="container">
  <div class="d-flex align-items-center mb-4">
    <a href="/admin/projects/{{assessment.project_id}}" class="btn btn-outline-primary me-3"><i class="bi bi-arrow-left"></i></a>
    <div class="flex-grow-1">
      <h1 class="mb-0">{{assessment.project_name}}</h1>
      <p class="text-muted mb-0">Assessment Package — {{{statusBadge assessment.status}}}</p>
    </div>
  </div>

  <!-- Status & Actions Bar -->
  <div class="card mb-4">
    <div class="card-body">
      <div class="row g-3 align-items-center">
        <div class="col-md-8">
          <div class="d-flex flex-wrap gap-3 align-items-center">
            <div>
              <span class="small text-muted d-block">Invite Code</span>
              <code class="fs-5 fw-bold">{{assessment.invite_code}}</code>
            </div>
            <div class="vr d-none d-md-block"></div>
            <div>
              <span class="small text-muted d-block">Owner</span>
              <span class="fw-semibold">{{assessment.project_owner_name}}</span>
            </div>
            <div class="vr d-none d-md-block"></div>
            <div>
              <span class="small text-muted d-block">Classification</span>
              <span class="badge bg-info">{{assessment.data_classification}}</span>
            </div>
            {{#if assessment.overall_score}}
              <div class="vr d-none d-md-block"></div>
              <div>
                <span class="small text-muted d-block">Score</span>
                <span class="fw-bold fs-5 {{#ifCond assessment.overall_score '>=' 80}}text-success{{else}}text-danger{{/ifCond}}">
                  {{assessment.overall_score}}%
                </span>
              </div>
            {{/if}}
            {{#if assessment.result}}
              <div class="vr d-none d-md-block"></div>
              <div>
                <span class="small text-muted d-block">Result</span>
                {{{statusBadge assessment.result}}}
              </div>
            {{/if}}
          </div>
        </div>
        <div class="col-md-4 text-md-end">
          <div class="d-flex flex-wrap gap-2 justify-content-md-end">
            {{!-- Action buttons based on status --}}
            {{#eq assessment.status "draft"}}
              <a href="/admin/assessments/{{assessment.id}}/manage-controls" class="btn btn-outline-primary">
                <i class="bi bi-gear me-1"></i>Manage Controls
              </a>
              <form method="POST" action="/admin/assessments/{{assessment.id}}/send-invite" class="d-inline">
                <button class="btn btn-primary"><i class="bi bi-send me-1"></i>Send Invite</button>
              </form>
              <form method="POST" action="/admin/assessments/{{assessment.id}}/delete" class="d-inline mfa-protected" data-mfa-label="Deleting assessment permanently"
                onsubmit="return confirm('Delete this draft assessment? This cannot be undone.')">
                <input type="hidden" name="return_to" value="/admin/projects/{{assessment.project_id}}">
                <button class="btn btn-outline-danger"><i class="bi bi-trash me-1"></i>Delete</button>
              </form>
            {{/eq}}

            {{#eq assessment.status "evidence-gathering"}}
              <a href="/admin/assessments/{{assessment.id}}/manage-controls" class="btn btn-outline-primary btn-sm">
                <i class="bi bi-gear me-1"></i>Manage Controls
              </a>
              <form method="POST" action="/admin/assessments/{{assessment.id}}/send-invite" class="d-inline">
                <button class="btn btn-outline-primary btn-sm"><i class="bi bi-send me-1"></i>Resend Invite</button>
              </form>
              <a href="/respond/{{assessment.invite_code}}" target="_blank" class="btn btn-outline-success btn-sm" title="Open the public evidence submission portal">
                <i class="bi bi-box-arrow-up-right me-1"></i>Open Portal
              </a>
            {{/eq}}

            {{#eq assessment.status "submitted"}}
              <button class="btn btn-info me-1" id="aiReviewBtn" data-assessment-id="{{assessment.id}}">
                <i class="bi bi-stars me-1"></i>AI Pre-Review Evidence
              </button>
              <form method="POST" action="/admin/assessments/{{assessment.id}}/start-audit" class="d-inline">
                <button class="btn btn-warning"><i class="bi bi-search me-1"></i>Start Audit</button>
              </form>
              <form method="POST" action="/admin/assessments/{{assessment.id}}/reactivate" class="d-inline mfa-protected" data-mfa-label="Reactivating assessment for client edits">
                <button class="btn btn-outline-secondary btn-sm"><i class="bi bi-unlock me-1"></i>Reactivate</button>
              </form>
            {{/eq}}

            {{#eq assessment.status "audit"}}
              <button class="btn btn-info btn-sm me-1" id="aiReviewBtn" data-assessment-id="{{assessment.id}}">
                <i class="bi bi-stars me-1"></i>AI Pre-Review
              </button>
            {{/eq}}

            {{#eq assessment.status "audit"}}
              <button class="btn btn-success" data-bs-toggle="collapse" data-bs-target="#completeAuditForm">
                <i class="bi bi-check-circle me-1"></i>Complete Audit
              </button>
            {{/eq}}

            {{#eq assessment.status "completed"}}
              <a href="/admin/assessments/{{assessment.id}}/generate-ato" class="btn btn-success">
                <i class="bi bi-file-earmark-pdf me-1"></i>Generate {{#if assessment.ato_type}}{{assessment.ato_type}}{{else}}ATO{{/if}}
              </a>
            {{/eq}}

            <a href="/admin/assessments/{{assessment.id}}/export-pdf" class="btn btn-outline-primary btn-sm">
              <i class="bi bi-download me-1"></i>Export PDF
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Stats -->
  <div class="row g-3 mb-4">
    <div class="col-6 col-lg">
      <div class="stat-card">
        <div class="stat-number">{{stats.total}}</div>
        <div class="stat-label">Total Controls</div>
      </div>
    </div>
    <div class="col-6 col-lg">
      <div class="stat-card">
        <div class="stat-number">{{stats.inherited}}</div>
        <div class="stat-label">Inherited</div>
      </div>
    </div>
    <div class="col-6 col-lg">
      <div class="stat-card">
        <div class="stat-number">{{stats.evidenceProvided}}</div>
        <div class="stat-label">Evidence Provided</div>
      </div>
    </div>
    <div class="col-6 col-lg">
      <div class="stat-card">
        <div class="stat-number text-success">{{stats.met}}</div>
        <div class="stat-label">Met</div>
      </div>
    </div>
    <div class="col-6 col-lg">
      <div class="stat-card">
        <div class="stat-number" style="color:var(--gc-warning)">{{stats.partiallyMet}}</div>
        <div class="stat-label">Partially Met</div>
      </div>
    </div>
    <div class="col-6 col-lg">
      <div class="stat-card">
        <div class="stat-number text-danger">{{stats.notMet}}</div>
        <div class="stat-label">Not Met</div>
      </div>
    </div>
    <div class="col-6 col-lg">
      <div class="stat-card">
        <div class="stat-number" style="color:#dc3545">{{stats.highRisk}}</div>
        <div class="stat-label">High Risk (TBS)</div>
      </div>
    </div>
  </div>

  {{#if multiFramework}}
  <!-- Multi-Framework Scope -->
  <div class="card mb-4 border-primary">
    <div class="card-body py-2">
      <div class="d-flex align-items-center mb-2">
        <i class="bi bi-shield-check text-primary me-2 fs-5"></i>
        <strong class="small">Frameworks in Scope ({{frameworkSummary.length}})</strong>
      </div>
      <div class="d-flex flex-wrap gap-2">
        {{#each frameworkSummary}}
        <span class="badge bg-primary bg-opacity-10 text-primary border border-primary px-2 py-1" style="font-size:0.8rem">
          <strong>{{this.name}}</strong>
          <span class="text-muted ms-1">{{this.country}}</span>
          <span class="badge bg-primary ms-1" style="font-size:0.65rem">{{this.controlCount}} ctrl</span>
        </span>
        {{/each}}
      </div>
    </div>
  </div>
  {{/if}}

  {{!-- Score Bar (when audit is done or in progress) --}}
  {{#or stats.met stats.partiallyMet stats.notMet}}
    <div class="card mb-4">
      <div class="card-body">
        <div class="d-flex justify-content-between mb-2">
          <span class="fw-semibold">Audit Progress</span>
          <span class="fw-bold">{{stats.score}}%</span>
        </div>
        <div class="progress" style="height:12px">
          <div class="progress-bar bg-success" style="width:{{percentage stats.met stats.applicable}}%"
            title="Met: {{stats.met}}"></div>
          <div class="progress-bar" style="width:{{percentage stats.partiallyMet stats.applicable}}%;background:var(--gc-warning)"
            title="Partially Met: {{stats.partiallyMet}}"></div>
          <div class="progress-bar bg-danger" style="width:{{percentage stats.notMet stats.applicable}}%"
            title="Not Met: {{stats.notMet}}"></div>
        </div>
        <div class="d-flex gap-3 mt-2 small">
          <span><i class="bi bi-circle-fill text-success"></i> Met ({{stats.met}})</span>
          <span><i class="bi bi-circle-fill" style="color:var(--gc-warning)"></i> Partial ({{stats.partiallyMet}})</span>
          <span><i class="bi bi-circle-fill text-danger"></i> Not Met ({{stats.notMet}})</span>
          <span><i class="bi bi-circle-fill text-secondary"></i> Pending ({{stats.pending}})</span>
        </div>
      </div>
    </div>
  {{/or}}

  {{!-- Complete Audit Form (collapsible) --}}
  {{#eq assessment.status "audit"}}
  <div class="collapse mb-4" id="completeAuditForm">
    <div class="card border-warning">
      <div class="card-header bg-warning text-dark fw-bold">
        <i class="bi bi-shield-check me-2"></i>Complete Audit — TBS Authorization Decision
      </div>
      <div class="card-body">
        <form method="POST" action="/admin/assessments/{{assessment.id}}/complete-audit"
          onsubmit="return confirm('Complete the audit and issue the authorization decision?')" class="mfa-protected" data-mfa-label="Completing audit — ATO determination">
          <div class="row g-3 mb-3">
            <div class="col-6 col-md-3">
              <div class="p-2 rounded text-center" style="background:#fef2f2">
                <div class="fw-bold text-danger fs-5">{{stats.highRiskNotMet}}</div>
                <small class="text-muted">High-Risk Findings</small>
              </div>
            </div>
            <div class="col-6 col-md-3">
              <div class="p-2 rounded text-center" style="background:#f0fdf4">
                <div class="fw-bold text-success fs-5">{{stats.met}}</div>
                <small class="text-muted">Controls Met</small>
              </div>
            </div>
            <div class="col-6 col-md-3">
              <div class="p-2 rounded text-center" style="background:#fffbeb">
                <div class="fw-bold" style="color:var(--gc-warning)">{{stats.partiallyMet}}</div>
                <small class="text-muted">Partially Met</small>
              </div>
            </div>
            <div class="col-6 col-md-3">
              <div class="p-2 rounded text-center" style="background:#fef2f2">
                <div class="fw-bold text-danger">{{stats.notMet}}</div>
                <small class="text-muted">Not Met</small>
              </div>
            </div>
          </div>
          {{#if stats.highRiskNotMet}}
          <div class="alert alert-danger py-2 small mb-3">
            <i class="bi bi-exclamation-triangle me-1"></i>
            <strong>TBS Policy:</strong> {{stats.highRiskNotMet}} high-risk control(s) not met. Per TBS Directive on Security Management, full ATO cannot be granted with outstanding high-risk findings. Consider iATO with POA&M.
          </div>
          {{/if}}
          <div class="row g-3 mb-3">
            <div class="col-md-4">
              <label class="form-label small fw-bold">Override Result</label>
              <select class="form-select form-select-sm" name="overrideResult">
                <option value="">Auto-calculate (TBS rules)</option>
                <option value="ato">ATO — Full Authority</option>
                <option value="iato">iATO — Interim + POA&M</option>
                <option value="denied">Denied</option>
              </select>
            </div>
            <div class="col-md-4">
              <label class="form-label small fw-bold">iATO Expiry Date</label>
              <input type="date" class="form-control form-control-sm" name="atoExpiryDate">
              <small class="text-muted">Default: 90 days if iATO</small>
            </div>
            <div class="col-md-4">
              <label class="form-label small fw-bold">POA&M Notes</label>
              <input type="text" class="form-control form-control-sm" name="poamNotes" placeholder="POA&M context notes...">
            </div>
          </div>
          <div class="mb-3">
            <label class="form-label small fw-bold">Risk Acceptance Statement <span class="text-muted fw-normal">(required for iATO per TBS)</span></label>
            <textarea class="form-control form-control-sm" name="riskAcceptance" rows="3"
              placeholder="Document residual risk acceptance rationale per TBS Directive on Security Management..."></textarea>
          </div>
          <button type="submit" class="btn btn-success"><i class="bi bi-shield-check me-1"></i>Complete Audit & Issue Decision</button>
        </form>
      </div>
    </div>
  </div>
  {{/eq}}

  <!-- POA&M Section (replaces basic iATO checklist) -->
  {{#eq assessment.result "iato"}}
    <div class="card mb-4" id="poam-section">
      <div class="card-header d-flex justify-content-between align-items-center" style="background:var(--gc-warning)">
        <span><i class="bi bi-clipboard2-check me-2"></i><strong>Plan of Action & Milestones (POA&M)</strong></span>
        <div class="d-flex gap-2">
          <form method="POST" action="/admin/assessments/{{assessment.id}}/poam/auto-populate" class="d-inline">
            <button class="btn btn-sm btn-outline-dark" title="Auto-generate from findings">
              <i class="bi bi-lightning me-1"></i>Auto-Populate
            </button>
          </form>
          <span class="badge bg-dark">{{poamStats.total}} items</span>
        </div>
      </div>
      <div class="card-body">
        {{#if assessment.risk_acceptance_statement}}
          <div class="alert alert-info py-2 small mb-3">
            <i class="bi bi-shield-exclamation me-1"></i><strong>Risk Acceptance:</strong> {{assessment.risk_acceptance_statement}}
          </div>
        {{/if}}
        {{#if assessment.ato_expiry_date}}
          <div class="d-flex gap-3 small mb-3 flex-wrap">
            <span><i class="bi bi-calendar-event me-1"></i>Expires: <strong>{{formatDate assessment.ato_expiry_date}}</strong></span>
            <span class="badge bg-danger">{{poamStats.highCount}} High</span>
            <span class="badge bg-warning text-dark">{{poamStats.mediumCount}} Medium</span>
            <span class="badge bg-info">{{poamStats.lowCount}} Low</span>
            {{#if poamStats.overdue}}<span class="badge bg-danger"><i class="bi bi-exclamation-triangle me-1"></i>{{poamStats.overdue}} Overdue</span>{{/if}}
          </div>
        {{/if}}

        <!-- POA&M Progress -->
        {{#if poamStats.total}}
        <div class="progress mb-3" style="height:8px">
          <div class="progress-bar bg-success" style="width:{{percentage poamStats.verified poamStats.total}}%" title="Verified: {{poamStats.verified}}"></div>
          <div class="progress-bar" style="width:{{percentage poamStats.completed poamStats.total}}%;background:#17a2b8" title="Completed: {{poamStats.completed}}"></div>
          <div class="progress-bar" style="width:{{percentage poamStats.inProgress poamStats.total}}%;background:var(--gc-warning)" title="In Progress: {{poamStats.inProgress}}"></div>
        </div>
        <div class="d-flex gap-3 small mb-3">
          <span><i class="bi bi-circle-fill text-secondary"></i> Open ({{poamStats.open}})</span>
          <span><i class="bi bi-circle-fill" style="color:var(--gc-warning)"></i> In Progress ({{poamStats.inProgress}})</span>
          <span><i class="bi bi-circle-fill" style="color:#17a2b8"></i> Completed ({{poamStats.completed}})</span>
          <span><i class="bi bi-circle-fill text-success"></i> Verified ({{poamStats.verified}})</span>
        </div>

        <div class="table-responsive">
          <table class="table table-hover table-sm mb-0" style="font-size:.85rem">
            <thead>
              <tr>
                <th style="width:30px">Risk</th>
                <th>Item</th>
                <th style="width:70px">Control</th>
                <th style="width:100px">Deadline</th>
                <th style="width:100px">Assigned</th>
                <th style="width:120px">Status</th>
                <th style="width:60px"></th>
              </tr>
            </thead>
            <tbody>
              {{#each checklistItems}}
                <tr class="{{#eq this.status 'verified'}}table-success{{/eq}} {{#eq this.status 'completed'}}table-info{{/eq}}">
                  <td>
                    {{#eq this.risk_level "high"}}<span class="badge bg-danger">H</span>{{/eq}}
                    {{#eq this.risk_level "medium"}}<span class="badge bg-warning text-dark">M</span>{{/eq}}
                    {{#eq this.risk_level "low"}}<span class="badge bg-info">L</span>{{/eq}}
                  </td>
                  <td>
                    <span class="fw-semibold">{{this.description}}</span>
                    {{#if this.original_finding}}<br><small class="text-muted">Finding: {{this.original_finding}}</small>{{/if}}
                    {{#if this.remediation_plan}}<br><small class="text-primary">Plan: {{this.remediation_plan}}</small>{{/if}}
                  </td>
                  <td><code>{{this.control_id}}</code></td>
                  <td>
                    <small>{{formatDate this.deadline}}</small>
                    {{#if this.deadline}}
                      {{!-- Highlight overdue --}}
                    {{/if}}
                  </td>
                  <td><small>{{this.assigned_to}}</small></td>
                  <td>
                    <form method="POST" action="/admin/assessments/{{../assessment.id}}/poam/{{this.id}}/update" class="d-inline">
                      <select class="form-select form-select-sm" name="status" onchange="this.form.submit()" style="font-size:.78rem">
                        <option value="open" {{#eq this.status "open"}}selected{{/eq}}>Open</option>
                        <option value="in-progress" {{#eq this.status "in-progress"}}selected{{/eq}}>In Progress</option>
                        <option value="completed" {{#eq this.status "completed"}}selected{{/eq}}>Completed</option>
                        <option value="verified" {{#eq this.status "verified"}}selected{{/eq}}>Verified</option>
                      </select>
                    </form>
                  </td>
                  <td>
                    <form method="POST" action="/admin/assessments/{{../assessment.id}}/poam/{{this.id}}/delete"
                      onsubmit="return confirm('Remove this POA&M item?')" class="d-inline">
                      <button class="btn btn-sm btn-outline-danger p-0 px-1" title="Delete"><i class="bi bi-trash"></i></button>
                    </form>
                  </td>
                </tr>
              {{/each}}
            </tbody>
          </table>
        </div>
        {{else}}
          <p class="text-muted mb-3">No POA&M items yet. Use "Auto-Populate" to generate from audit findings, or add manually below.</p>
        {{/if}}

        <!-- Add POA&M Item -->
        <hr>
        <h6 class="fw-semibold mb-3"><i class="bi bi-plus-circle me-1"></i>Add POA&M Item</h6>
        <form method="POST" action="/admin/assessments/{{assessment.id}}/checklist/add" class="">
          <div class="row g-2 mb-2">
            <div class="col-md-4">
              <input type="text" class="form-control form-control-sm" name="description" placeholder="Remediation item description" required>
            </div>
            <div class="col-md-2">
              <select class="form-select form-select-sm" name="control_id">
                <option value="">Control</option>
                {{#each controls}}
                  {{#or (eq this.audit_result "not-met") (eq this.audit_result "partially-met")}}
                    <option value="{{this.control_id}}">{{this.control_id}}</option>
                  {{/or}}
                {{/each}}
              </select>
            </div>
            <div class="col-md-1">
              <select class="form-select form-select-sm" name="risk_level">
                <option value="high">High</option>
                <option value="medium" selected>Medium</option>
                <option value="low">Low</option>
              </select>
            </div>
            <div class="col-md-2">
              <input type="date" class="form-control form-control-sm" name="deadline" required>
            </div>
            <div class="col-md-2">
              <input type="text" class="form-control form-control-sm" name="assigned_to" placeholder="Assigned to">
            </div>
            <div class="col-md-1">
              <button class="btn btn-sm btn-warning w-100"><i class="bi bi-plus-lg"></i></button>
            </div>
          </div>
          <div class="row g-2">
            <div class="col-md-6">
              <input type="text" class="form-control form-control-sm" name="remediation_plan" placeholder="Remediation plan (optional)">
            </div>
            <div class="col-md-6">
              <input type="text" class="form-control form-control-sm" name="milestone" placeholder="Milestone (optional)">
            </div>
          </div>
        </form>
      </div>
    </div>
  {{/eq}}

  <!-- Layout: Controls + Family Nav -->
  <div class="row">
    <div class="col-lg-9">

  <!-- Mobile Family Nav -->
  <div class="d-lg-none family-nav-mobile">
    {{#each families}}
      <a href="#family-{{this.code}}" class="family-nav-item" data-family="{{this.code}}">
        <span class="family-nav-code">{{this.code}}</span>
        <span class="family-nav-count">{{this.controls.length}}</span>
      </a>
    {{/each}}
  </div>

  <!-- Control Families -->
  {{#each families}}
    <div class="form-section" id="family-{{this.code}}">
      <div class="section-header">
        <h3 class="section-title">
          <span class="section-number">{{this.code}}</span>
          {{this.name}}
        </h3>
        <p class="section-description">{{this.controls.length}} control(s)</p>
      </div>

      {{#each this.controls}}
        <div class="control-card {{#if this.is_inherited}}inherited{{/if}}" id="control-{{this.id}}">
          <div class="d-flex justify-content-between align-items-start">
            <div>
              <div class="d-flex align-items-center gap-2 mb-1">
                {{{controlResultIcon this.audit_result}}}
                <span class="control-id">{{this.control_id}}</span>
                <span class="control-title">{{this.title}}</span>
              </div>
              {{#if this.is_inherited}}
                <span class="badge bg-info mb-1"><i class="bi bi-arrow-left-right me-1"></i>Inherited: {{this.inherited_from}}</span>
              {{/if}}
              {{#if ../../multiFramework}}
                <div class="d-flex flex-wrap gap-1 mt-1">
                  {{#each (parseJson this.frameworks)}}
                    <span class="badge bg-primary bg-opacity-10 text-primary border" style="font-size:0.65rem">{{this}}</span>
                  {{/each}}
                  {{#if this.source_framework}}
                    {{#neq this.source_framework 'ITSG-33'}}
                      <span class="badge bg-warning text-dark" style="font-size:0.65rem"><i class="bi bi-plus-circle me-1"></i>{{this.source_framework}}</span>
                    {{/neq}}
                  {{/if}}
                </div>
              {{/if}}
            </div>
            <div class="d-flex gap-1">
              <span class="badge bg-secondary">{{this.priority}}</span>
              {{#eq this.risk_level "high"}}<span class="badge bg-danger">High Risk</span>{{/eq}}
              {{#eq this.risk_level "medium"}}<span class="badge bg-warning text-dark">Med Risk</span>{{/eq}}
              {{#eq this.risk_level "low"}}<span class="badge bg-info">Low Risk</span>{{/eq}}
              {{#if this.audit_result}}{{{statusBadge this.audit_result}}}{{/if}}
            </div>
          </div>

          {{#if this.tailored_description}}
            <div class="mt-2 p-2 rounded" style="background:#f8f9fa">
              <small class="text-muted fw-semibold d-block mb-1">Tailored Description</small>
              <small>{{this.tailored_description}}</small>
            </div>
          {{/if}}

          {{#if this.evidence_guidance}}
            <div class="mt-2 p-2 rounded" style="background:#fff8e1">
              <small class="text-muted fw-semibold d-block mb-1"><i class="bi bi-info-circle me-1"></i>Evidence Guidance</small>
              <small>{{this.evidence_guidance}}</small>
            </div>
          {{/if}}

