<script>
async function auditControl(controlId, assessmentId, result, btn, comments) {
  const payload = {};
  if (result) {
    payload.result = result;
    // Deactivate siblings, activate this
    if (btn) {
      btn.closest('.audit-row').querySelectorAll('.audit-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
    }
  }
  const commentEl = document.getElementById('audit-comment-' + controlId);
  payload.comments = comments || (commentEl ? commentEl.value : '');
  if (result) payload.result = result;

  try {
    await fetch('/admin/assessments/' + assessmentId + '/audit-control/' + controlId, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload)
    });
  } catch(e) { console.error(e); }
}

async function loadComments(controlId) {
  try {
    const res = await fetch('/api/comments/' + controlId);
    const data = await res.json();
    const thread = document.getElementById('thread-' + controlId);
    if (data.comments && data.comments.length) {
      thread.innerHTML = data.comments.map(c =>
        '<div class="comment-item">' +
        '<span class="comment-author">' + c.user_name + '</span> ' +
        '<span class="comment-time">' + new Date(c.created_at).toLocaleString() + '</span>' +
        '<div>' + c.content + '</div></div>'
      ).join('');
    } else {
      thread.innerHTML = '<div class="text-muted small text-center py-2">No comments yet</div>';
    }
  } catch(e) { console.error(e); }
}

async function addComment(controlId, assessmentId) {
  const input = document.getElementById('commentInput-' + controlId);
  if (!input.value.trim()) return;
  try {
    await fetch('/api/comments/' + controlId, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ content: input.value, user_name: '{{admin.name}}', user_role: 'assessor' })
    });
    input.value = '';
    loadComments(controlId);
  } catch(e) { console.error(e); }
}

// Load comments when expanded
document.querySelectorAll('[id^="comments-"]').forEach(el => {
  el.addEventListener('show.bs.collapse', () => {
    const controlId = el.id.replace('comments-', '');
    loadComments(controlId);
  });
});
</script>

{{> ai-panel }}

<script>
// ═══════════════════════════════════════════════════════════════════════════════
// AI EVIDENCE NARRATIVE GENERATION
// ═══════════════════════════════════════════════════════════════════════════════
const PROJECT_CONTEXT = {{{projectContextJSON}}};
const ASSESSMENT_ID = '{{assessment.id}}';

// ── Single control evidence GUIDANCE generation (assessor generates for client) ──
async function aiGenerateGuidance(controlDbId, controlId, title) {
  const btn = document.getElementById('ai-ev-btn-' + controlDbId);
  const statusEl = document.getElementById('ai-ev-status-' + controlDbId);
  const resultEl = document.getElementById('ai-ev-result-' + controlDbId);

  btn.disabled = true;
  btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Generating...';
  statusEl.style.display = 'inline';
  statusEl.textContent = 'AI is drafting evidence guidance for the client...';

  try {
    const resp = await fetch('/api/ai/evidence-guidance', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        controlId, controlTitle: title,
        controlDescription: title,
        projectContext: PROJECT_CONTEXT
      })
    });
    const data = await resp.json();
    if (!data.success) throw new Error(data.error || 'Failed');

    resultEl.style.display = 'block';
    resultEl.innerHTML = `
      <div style="background:#f5f3ff; border:1px solid #e9d5ff; border-radius:8px; padding:12px;">
        <div class="d-flex justify-content-between align-items-center mb-2">
          <small class="fw-semibold" style="color:#6d28d9;"><i class="bi bi-stars me-1"></i>AI-Generated Evidence Guidance</small>
          <div class="d-flex gap-1">
            <button class="btn btn-sm btn-outline-success" style="font-size:.75rem;" onclick="aiSaveGuidance(${controlDbId})">
              <i class="bi bi-check-lg me-1"></i>Save to Control
            </button>
            <button class="btn btn-sm btn-outline-secondary" style="font-size:.75rem;" onclick="aiCopyNarrative(this, ${controlDbId})">
              <i class="bi bi-clipboard me-1"></i>Copy
            </button>
          </div>
        </div>
        <div class="small" style="white-space:pre-wrap; line-height:1.6;" id="ai-narrative-text-${controlDbId}">${data.guidance}</div>
        <small class="text-muted d-block mt-2"><i class="bi bi-info-circle me-1"></i>This guidance will be shown to the client in their evidence submission portal.</small>
      </div>`;

    statusEl.textContent = 'Guidance ready — click "Save to Control" to attach it.';
    statusEl.style.color = '#16a34a';
    btn.innerHTML = '<i class="bi bi-stars me-1"></i>Regenerate Guidance';
    btn.disabled = false;
  } catch (err) {
    statusEl.textContent = 'Error: ' + err.message;
    statusEl.style.color = '#dc3545';
    btn.innerHTML = '<i class="bi bi-stars me-1"></i>Retry';
    btn.disabled = false;
  }
}

// ── Save AI guidance to the control's evidence_guidance field ──
async function aiSaveGuidance(controlDbId) {
  const text = document.getElementById('ai-narrative-text-' + controlDbId).textContent;
  try {
    const resp = await fetch('/api/ai/save-guidance/' + controlDbId, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ guidance: text })
    });
    const data = await resp.json();
    if (data.success) {
      const statusEl = document.getElementById('ai-ev-status-' + controlDbId);
      statusEl.textContent = '✓ Guidance saved — client will see it in their portal.';
      statusEl.style.color = '#16a34a';
      // Update the guidance display on page if it exists
      const card = document.getElementById('control-' + controlDbId) || document.getElementById('ai-ev-btn-' + controlDbId)?.closest('.control-card');
      if (card) {
        let guidanceEl = card.querySelector('[style*="fff8e1"]');
        if (guidanceEl) {
          guidanceEl.querySelector('small:last-child').textContent = text;
        } else {
          const newEl = document.createElement('div');
          newEl.className = 'mt-2 p-2 rounded';
          newEl.style.background = '#fff8e1';
          newEl.innerHTML = '<small class="text-muted fw-semibold d-block mb-1"><i class="bi bi-lightbulb me-1"></i>Evidence Guidance</small><small>' + text + '</small>';
          const aiSection = document.getElementById('ai-ev-result-' + controlDbId);
          if (aiSection) aiSection.parentNode.insertBefore(newEl, aiSection);
        }
      }
    }
  } catch(e) { console.error(e); }
}

// ── Copy narrative to clipboard ──────────────────────────────────────────────
function aiCopyNarrative(btn, controlDbId) {
  const text = document.getElementById('ai-narrative-text-' + controlDbId).textContent;
  navigator.clipboard.writeText(text).then(() => {
    btn.innerHTML = '<i class="bi bi-check2 me-1"></i>Copied!';
    setTimeout(() => { btn.innerHTML = '<i class="bi bi-clipboard me-1"></i>Copy'; }, 2000);
  });
}

// ── Bulk evidence guidance generation (via AI FAB) ────────────────────────────
async function aiBulkEvidence() {
  AIPanel.open({ title: 'Bulk Evidence Guidance', subtitle: 'Generate guidance for multiple controls' });
  AIPanel.showLoading('Preparing controls list...');

  const controlEls = document.querySelectorAll('[id^="ai-ev-btn-"]');
  const totalControls = controlEls.length;

  let html = `
    <div class="ai-section">
      <div class="ai-section-title">Bulk Evidence Guidance Generator</div>
      <div class="small mb-3">Generate AI evidence guidance for controls. This tells clients <strong>what to provide</strong> — the guidance appears in their evidence submission portal.</div>
      <div class="p-3 rounded" style="background:#f5f3ff; border:1px solid #e9d5ff;">
        <div class="fw-bold small mb-1">${totalControls} controls available</div>
        <div class="small text-muted">Each control takes ~3-5 seconds. Guidance will appear inline next to each control.</div>
      </div>
    </div>
    <div class="ai-section mt-3">
      <div class="ai-section-title">Select Batch Size</div>
      <div class="d-flex gap-2 flex-wrap">
        <button class="btn btn-sm btn-outline-primary" onclick="aiRunBulk(5)">First 5 controls</button>
        <button class="btn btn-sm btn-outline-primary" onclick="aiRunBulk(10)">First 10 controls</button>
        <button class="btn btn-sm btn-outline-primary" onclick="aiRunBulk(20)">First 20 controls</button>
      </div>
    </div>
    <div id="ai-bulk-progress" class="mt-3" style="display:none;"></div>`;

  AIPanel.open({
    title: 'Bulk Evidence Guidance',
    subtitle: totalControls + ' controls in assessment',
    body: html,
    footer: `<button class="btn btn-sm btn-outline-secondary w-100" onclick="AIPanel.close()">Close</button>`
  });
}

async function aiRunBulk(count) {
  const progressEl = document.getElementById('ai-bulk-progress');
  progressEl.style.display = 'block';
  progressEl.innerHTML = '<div class="small"><i class="bi bi-hourglass-split me-1"></i>Starting...</div>';

  const btns = Array.from(document.querySelectorAll('[id^="ai-ev-btn-"]')).slice(0, count);

  for (let i = 0; i < btns.length; i++) {
    progressEl.innerHTML = `
      <div class="small mb-1"><i class="bi bi-hourglass-split me-1"></i>Generating ${i + 1} of ${btns.length}...</div>
      <div class="progress" style="height:6px;">
        <div class="progress-bar" style="width:${((i + 1) / btns.length * 100).toFixed(0)}%; background:#8b5cf6;"></div>
      </div>`;

    // Trigger the individual generate function
    btns[i].click();
    // Wait for completion
    await new Promise(resolve => setTimeout(resolve, 6000));
  }

  progressEl.innerHTML = `
    <div class="small text-success"><i class="bi bi-check-circle me-1"></i>Generated ${btns.length} evidence guidance items. Review each one and click "Save to Control" to attach.</div>`;
}

// Override AI FAB button to open bulk evidence generator
document.addEventListener('DOMContentLoaded', function() {
  var fab = document.getElementById('aiTriggerBtn');
  if (fab) {
    fab.onclick = function(e) {
      e.preventDefault();
      aiBulkEvidence();
    };
    fab.title = 'AI: Generate Evidence Guidance for Client';
  }

  // ── Family Nav: scroll spy + filter ──
  const familySections = document.querySelectorAll('[id^="family-"]');
  const navItems = document.querySelectorAll('.family-nav-item');
  const filterInput = document.getElementById('familyFilter');

  // Scroll spy
  if (familySections.length && navItems.length) {
    const observer = new IntersectionObserver(entries => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const id = entry.target.id;
          navItems.forEach(item => {
            item.classList.toggle('active', item.getAttribute('href') === '#' + id);
          });
        }
      });
    }, { rootMargin: '-80px 0px -70% 0px', threshold: 0 });

    familySections.forEach(sec => observer.observe(sec));

    // Smooth scroll
    navItems.forEach(item => {
      item.addEventListener('click', function(e) {
        e.preventDefault();
        const target = document.querySelector(this.getAttribute('href'));
        if (target) {
          target.scrollIntoView({ behavior: 'smooth', block: 'start' });
          // Offset for fixed header
          setTimeout(() => window.scrollBy(0, -80), 300);
        }
      });
    });
  }

  // Family filter
  if (filterInput) {
    filterInput.addEventListener('input', function() {
      const q = this.value.toLowerCase();
      navItems.forEach(item => {
        const code = item.dataset.family || '';
        const name = item.querySelector('.family-nav-name')?.textContent || '';
        item.style.display = (code.toLowerCase().includes(q) || name.toLowerCase().includes(q)) ? '' : 'none';
      });
    });
  }
});
</script>

<script>
// AI Evidence Pre-Review
document.addEventListener('DOMContentLoaded', function() {
  const aiBtn = document.getElementById('aiReviewBtn');
  if (aiBtn) {
    aiBtn.addEventListener('click', async function() {
      const assessmentId = this.dataset.assessmentId;
      const origHTML = this.innerHTML;
      this.disabled = true;
      this.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>AI Reviewing Evidence...';

      try {
        const resp = await fetch('/api/ai/review-evidence/' + assessmentId, {
          method: 'POST', headers: { 'Content-Type': 'application/json' }
        });
        const data = await resp.json();

        if (data.success && data.reviews) {
          // Auto-populate audit results from AI review
          let populated = 0;
          data.reviews.forEach(r => {
            // Map AI result to audit result
            let auditResult = null;
            if (r.result === 'met') auditResult = 'met';
            else if (r.result === 'partial') auditResult = 'partially-met';
            else if (r.result === 'not-met') auditResult = 'not-met';

            if (auditResult) {
              // Find the audit buttons for this control and click the right one
              const commentInput = document.getElementById('audit-comment-' + r.controlDbId);
              if (commentInput) {
                // Set comment
                commentInput.value = '[AI] ' + (r.comments || '');
                // Trigger the audit API call
                auditControl(r.controlDbId, assessmentId, auditResult, null, commentInput.value);
                // Highlight the active button
                const row = commentInput.closest('.audit-row');
                if (row) {
                  row.querySelectorAll('.audit-btn').forEach(b => b.classList.remove('active'));
                  if (auditResult === 'met') row.querySelector('.audit-btn.met')?.classList.add('active');
                  else if (auditResult === 'partially-met') row.querySelector('.audit-btn.partial')?.classList.add('active');
                  else if (auditResult === 'not-met') row.querySelector('.audit-btn.not-met')?.classList.add('active');
                }
                populated++;
              }
            }
          });

          this.className = 'btn btn-success me-1';
          this.innerHTML = '<i class="bi bi-check-circle me-1"></i>AI Reviewed ' + populated + '/' + data.total + ' Controls';
          setTimeout(() => {
            this.className = 'btn btn-info me-1 btn-sm';
            this.innerHTML = origHTML;
            this.disabled = false;
          }, 5000);
        } else {
          alert(data.error || 'AI review failed.');
          this.innerHTML = origHTML; this.disabled = false;
        }
      } catch (err) {
        alert('Error: ' + err.message);
        this.innerHTML = origHTML; this.disabled = false;
      }
    });
  }
});
