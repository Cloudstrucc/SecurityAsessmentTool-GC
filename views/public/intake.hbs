<div class="container py-4" style="max-width: 900px;">

  <!-- Header -->
  <div class="text-center mb-4">
    <div style="width:64px;height:64px;border-radius:16px;background:var(--gc-accent);display:flex;align-items:center;justify-content:center;margin:0 auto 1rem;">
      <i class="bi bi-clipboard2-data text-white" style="font-size:1.75rem;"></i>
    </div>
    <h2>Security Assessment Intake</h2>
    <p class="text-muted">Submit your project for a security assessment. We'll determine the right frameworks and controls based on your operating regions.</p>
  </div>

  {{#if success}}
  <div class="alert alert-success">
    <i class="bi bi-check-circle me-2"></i>
    <strong>Intake submitted successfully!</strong> Your submission reference is <strong>{{refCode}}</strong>. Our assessment team will review your submission and reach out to the project owner within 3–5 business days.
  </div>
  {{else}}

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!-- STEP 1: Region & Jurisdiction Selection                    -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <div id="wizardStep1">
    <div class="card border-primary mb-4">
      <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
        <strong><i class="bi bi-globe me-2"></i>Step 1 of 2 — Where Does This Application Operate?</strong>
        <span class="badge bg-light text-primary">Required</span>
      </div>
      <div class="card-body">
        <p class="text-muted mb-3">Select all regions and jurisdictions where this application will be deployed, store data, or serve users. This determines which security frameworks and compliance requirements apply.</p>

        <div class="row g-4">
          <!-- North America -->
          <div class="col-md-6">
            <div class="card h-100">
              <div class="card-header py-2 bg-light"><strong class="small"><i class="bi bi-geo-alt me-1"></i>North America</strong></div>
              <div class="card-body py-2">
                <div class="form-check mb-2">
                  <input class="form-check-input region-check" type="checkbox" value="canada" id="reg-canada" data-frameworks="ITSG-33,CCCS-MEDIUM" data-label="Canada (Federal)">
                  <label class="form-check-label" for="reg-canada">
                    <strong>Canada</strong> <small class="text-muted">— ITSG-33, CCCS Medium</small>
                  </label>
                </div>
                <div class="form-check mb-2 ms-3 region-sub" data-parent="canada" style="display:none">
                  <input class="form-check-input region-check" type="checkbox" value="canada-finance" id="reg-canada-fin" data-frameworks="OSFI-B13" data-label="Canada (Financial)">
                  <label class="form-check-label small" for="reg-canada-fin">
                    Financial sector <small class="text-muted">— OSFI B-13</small>
                  </label>
                </div>
                <div class="form-check mb-2">
                  <input class="form-check-input region-check" type="checkbox" value="usa" id="reg-usa" data-frameworks="NIST-800-53,FEDRAMP" data-label="United States">
                  <label class="form-check-label" for="reg-usa">
                    <strong>United States</strong> <small class="text-muted">— NIST 800-53, FedRAMP</small>
                  </label>
                </div>
                <div class="form-check mb-2 ms-3 region-sub" data-parent="usa" style="display:none">
                  <input class="form-check-input region-check" type="checkbox" value="usa-defense" id="reg-usa-def" data-frameworks="CMMC" data-label="US Defense">
                  <label class="form-check-label small" for="reg-usa-def">
                    Defense / DoD supply chain <small class="text-muted">— CMMC 2.0</small>
                  </label>
                </div>
                <div class="form-check mb-2 ms-3 region-sub" data-parent="usa" style="display:none">
                  <input class="form-check-input region-check" type="checkbox" value="usa-state" id="reg-usa-state" data-frameworks="STATERAMP" data-label="US State/Local">
                  <label class="form-check-label small" for="reg-usa-state">
                    State / local government <small class="text-muted">— StateRAMP</small>
                  </label>
                </div>
                <div class="form-check mb-2 ms-3 region-sub" data-parent="usa" style="display:none">
                  <input class="form-check-input region-check" type="checkbox" value="usa-finance" id="reg-usa-fin" data-frameworks="NYDFS-500" data-label="US Financial">
                  <label class="form-check-label small" for="reg-usa-fin">
                    NY financial services <small class="text-muted">— NYDFS 500</small>
                  </label>
                </div>
              </div>
            </div>
          </div>

          <!-- Europe -->
          <div class="col-md-6">
            <div class="card h-100">
              <div class="card-header py-2 bg-light"><strong class="small"><i class="bi bi-geo-alt me-1"></i>Europe</strong></div>
              <div class="card-body py-2">
                <div class="form-check mb-2">
                  <input class="form-check-input region-check" type="checkbox" value="eu" id="reg-eu" data-frameworks="NIS2" data-label="European Union">
                  <label class="form-check-label" for="reg-eu">
                    <strong>European Union</strong> <small class="text-muted">— NIS2 Directive</small>
                  </label>
                </div>
                <div class="form-check mb-2 ms-3 region-sub" data-parent="eu" style="display:none">
                  <input class="form-check-input region-check" type="checkbox" value="eu-finance" id="reg-eu-fin" data-frameworks="DORA" data-label="EU Financial">
                  <label class="form-check-label small" for="reg-eu-fin">
                    EU financial services <small class="text-muted">— DORA</small>
                  </label>
                </div>
                <div class="form-check mb-2">
                  <input class="form-check-input region-check" type="checkbox" value="germany" id="reg-germany" data-frameworks="BSI-GRUNDSCHUTZ" data-label="Germany">
                  <label class="form-check-label" for="reg-germany">
                    <strong>Germany</strong> <small class="text-muted">— BSI IT-Grundschutz</small>
                  </label>
                </div>
                <div class="form-check mb-2">
                  <input class="form-check-input region-check" type="checkbox" value="france" id="reg-france" data-frameworks="ANSSI-RGS" data-label="France">
                  <label class="form-check-label" for="reg-france">
                    <strong>France</strong> <small class="text-muted">— ANSSI RGS / EBIOS RM</small>
                  </label>
                </div>
                <div class="form-check mb-2">
                  <input class="form-check-input region-check" type="checkbox" value="uk" id="reg-uk" data-frameworks="NCSC-CAF" data-label="United Kingdom">
                  <label class="form-check-label" for="reg-uk">
                    <strong>United Kingdom</strong> <small class="text-muted">— NCSC CAF</small>
                  </label>
                </div>
                <div class="form-check mb-2">
                  <input class="form-check-input region-check" type="checkbox" value="spain" id="reg-spain" data-frameworks="ENS" data-label="Spain">
                  <label class="form-check-label" for="reg-spain">
                    <strong>Spain</strong> <small class="text-muted">— ENS (CCN-STIC)</small>
                  </label>
                </div>
              </div>
            </div>
          </div>

          <!-- Asia-Pacific -->
          <div class="col-md-6">
            <div class="card h-100">
              <div class="card-header py-2 bg-light"><strong class="small"><i class="bi bi-geo-alt me-1"></i>Asia-Pacific</strong></div>
              <div class="card-body py-2">
                <div class="form-check mb-2">
                  <input class="form-check-input region-check" type="checkbox" value="australia" id="reg-australia" data-frameworks="ASD-ISM,ASD-E8" data-label="Australia">
                  <label class="form-check-label" for="reg-australia">
                    <strong>Australia</strong> <small class="text-muted">— ASD ISM, Essential Eight</small>
                  </label>
                </div>
                <div class="form-check mb-2 ms-3 region-sub" data-parent="australia" style="display:none">
                  <input class="form-check-input region-check" type="checkbox" value="australia-finance" id="reg-au-fin" data-frameworks="APRA-CPS234" data-label="Australia Financial">
                  <label class="form-check-label small" for="reg-au-fin">
                    Financial sector <small class="text-muted">— APRA CPS 234</small>
                  </label>
                </div>
              </div>
            </div>
          </div>

          <!-- Global / Industry -->
          <div class="col-md-6">
            <div class="card h-100">
              <div class="card-header py-2 bg-light"><strong class="small"><i class="bi bi-globe2 me-1"></i>Global / Industry Standards</strong></div>
              <div class="card-body py-2">
                <div class="form-check mb-2">
                  <input class="form-check-input region-check" type="checkbox" value="global" id="reg-global" data-frameworks="ISO-27001" data-label="Global">
                  <label class="form-check-label" for="reg-global">
                    <strong>Global / Worldwide</strong> <small class="text-muted">— ISO 27001</small>
                  </label>
                </div>
                <div class="form-check mb-2">
                  <input class="form-check-input region-check" type="checkbox" value="soc2" id="reg-soc2" data-frameworks="SOC2" data-label="SOC 2">
                  <label class="form-check-label" for="reg-soc2">
                    <strong>SOC 2 Required</strong> <small class="text-muted">— Service organization controls</small>
                  </label>
                </div>
                <div class="form-check mb-2">
                  <input class="form-check-input region-check" type="checkbox" value="pci" id="reg-pci" data-frameworks="PCI-DSS" data-label="PCI DSS">
                  <label class="form-check-label" for="reg-pci">
                    <strong>Handles Payment Cards</strong> <small class="text-muted">— PCI DSS 4.0</small>
                  </label>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Summary -->
        <div class="mt-3 p-3 rounded" style="background:#f0f4ff" id="regionSummary">
          <div class="d-flex justify-content-between align-items-center">
            <div>
              <i class="bi bi-shield-check text-primary me-2"></i>
              <strong class="small" id="regionSummaryText">Select at least one region to continue</strong>
            </div>
            <div>
              <span class="small text-muted" id="suggestedFrameworksList"></span>
            </div>
          </div>
        </div>

        <div class="text-end mt-4">
          <button type="button" class="btn btn-primary btn-lg px-5" id="wizardContinueBtn" disabled>
            Continue to Intake Form <i class="bi bi-arrow-right ms-2"></i>
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!-- STEP 2: Intake Form (existing, adapted by region)          -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <div id="wizardStep2" style="display:none">

    <!-- Region context bar (shown during form entry) -->
    <div class="alert alert-primary d-flex justify-content-between align-items-center mb-3" id="regionContextBar">
      <div>
        <i class="bi bi-globe me-2"></i>
        <strong>Operating Regions:</strong>
        <span id="regionContextLabels"></span>
      </div>
      <button type="button" class="btn btn-sm btn-outline-primary" id="wizardBackBtn">
        <i class="bi bi-pencil me-1"></i>Change Regions
      </button>
    </div>

  <form method="POST" action="/intake" enctype="multipart/form-data" id="intakeForm" class="mfa-protected" data-mfa-label="Submitting security intake form">

    <!-- ─── AI Quick Start ─── -->
    <div class="form-section" style="border-left:3px solid #8b5cf6; background: linear-gradient(135deg, #faf5ff 0%, #f5f3ff 100%);">
      <div class="section-header" style="border-bottom-color:#e9d5ff;">
        <h4 class="section-title" style="color:#6d28d9;"><i class="bi bi-stars me-2"></i>AI-Assisted Intake <span class="badge bg-purple text-white" style="font-size:0.65rem; background:#8b5cf6 !important; vertical-align:middle;">BETA</span></h4>
        <p class="section-description">Upload a project document or describe your system in plain language and AI will suggest how to fill out this form.</p>
      </div>

      <div class="row g-3">
        <!-- Option A: Upload Document -->
        <div class="col-md-6">
          <div class="card h-100" style="border-color:#e9d5ff;">
            <div class="card-body">
              <h6 class="fw-bold mb-2"><i class="bi bi-file-earmark-arrow-up me-1 text-purple" style="color:#8b5cf6;"></i> Upload a Document</h6>
              <p class="text-muted small mb-2">Upload a design doc, SA, PIA, architecture diagram, or project charter (PDF, TXT, DOCX, PNG/JPG).</p>
              <input type="file" class="form-control form-control-sm" id="aiDocUpload" accept=".pdf,.txt,.md,.doc,.docx,.png,.jpg,.jpeg">
              <button type="button" class="btn btn-sm w-100 mt-2 text-white" style="background:#8b5cf6;" id="aiDocParseBtn" disabled onclick="aiParseDocument()">
                <i class="bi bi-stars me-1"></i>Analyze & Pre-fill
              </button>
            </div>
          </div>
        </div>

        <!-- Option B: Plain Language -->
        <div class="col-md-6">
          <div class="card h-100" style="border-color:#e9d5ff;">
            <div class="card-body">
              <h6 class="fw-bold mb-2"><i class="bi bi-chat-text me-1 text-purple" style="color:#8b5cf6;"></i> Describe Your Project</h6>
              <p class="text-muted small mb-2">Describe what your system does, who uses it, and what data it handles.</p>
              <textarea class="form-control form-control-sm" id="aiPlainDesc" rows="3" placeholder="e.g. We're building a portal for tax professionals to submit client returns. It connects to CRA mainframe and handles SIN, financial data. Hosted on Azure in Canada..."></textarea>
              <button type="button" class="btn btn-sm w-100 mt-2 text-white" style="background:#8b5cf6;" id="aiSuggestBtn" disabled onclick="aiSuggestFromDescription()">
                <i class="bi bi-stars me-1"></i>Get Suggestions
              </button>
            </div>
          </div>
        </div>
      </div>

      <!-- AI status message -->
      <div id="aiIntakeStatus" class="mt-2" style="display:none;"></div>
    </div>

    <!-- ─── Section 1: Project Information ─── -->
    <div class="form-section">
      <div class="section-header">
        <h4 class="section-title"><span class="section-number">1</span> Project Information</h4>
        <p class="section-description">Tell us about your project or system that requires a security assessment.</p>
      </div>

      <div class="mb-3">
        <label class="form-label" for="projectName">Project / System Name <span class="text-danger">*</span></label>
        <input type="text" class="form-control" id="projectName" name="projectName" required placeholder="e.g. HR Case Management Portal">
      </div>

      <div class="mb-3">
        <label class="form-label" for="projectDescription">Project Description <span class="text-danger">*</span></label>
        <textarea class="form-control" id="projectDescription" name="projectDescription" rows="4" required placeholder="Describe the purpose, scope, and key features of the system..."></textarea>
      </div>

      <div class="row g-3 mb-3">
        <div class="col-md-6">
          <label class="form-label" for="department" id="lbl-department">Department / Agency <span class="text-danger">*</span></label>
          <input type="text" class="form-control" id="department" name="department" required placeholder="e.g. Employment and Social Development Canada">
        </div>
        <div class="col-md-6">
          <label class="form-label" for="branch" id="lbl-branch">Branch / Directorate</label>
          <input type="text" class="form-control" id="branch" name="branch" placeholder="e.g. Innovation, Information and Technology Branch">
        </div>
      </div>

      <div class="row g-3 mb-3">
        <div class="col-md-4">
          <label class="form-label" for="targetDate">Target Go-Live Date</label>
          <input type="date" class="form-control" id="targetDate" name="targetDate">
        </div>
        <div class="col-md-4">
          <label class="form-label" for="userCount">Estimated User Count</label>
          <select class="form-select" id="userCount" name="userCount">
            <option value="">Select...</option>
            <option value="1-50">1 – 50</option>
            <option value="51-500">51 – 500</option>
            <option value="501-5000">501 – 5,000</option>
            <option value="5001+">5,000+</option>
          </select>
        </div>
        <div class="col-md-4">
          <label class="form-label" for="appType">Application Accessibility <span class="text-danger">*</span></label>
          <select class="form-select" id="appType" name="appType" required>
            <option value="">Select...</option>
            <option value="internal" id="appType-internal">Internal Only (GC network)</option>
            <option value="external">External / Public-Facing</option>
            <option value="hybrid">Hybrid (both internal & external)</option>
          </select>
        </div>
      </div>
    </div>

    <!-- ─── Section 2: Security Categorization ─── -->
    <div class="form-section" id="sec-categorization">
      <div class="section-header">
        <h4 class="section-title" id="sec2-title"><span class="section-number">2</span> Security Categorization</h4>
        <p class="section-description" id="sec2-desc">Categorize your system across three independent security dimensions per the <strong>TBS Directive on Security Management (Appendix J)</strong> and <strong>ITSG-33</strong>. The tool will automatically determine the applicable security control profile.</p>
      </div>

      <!-- ── 2A: Confidentiality ── -->
      <div class="card mb-3 border-0 bg-light">
        <div class="card-body">
          <h6 class="fw-bold mb-1" id="conf-heading"><i class="bi bi-shield-lock me-1"></i> Confidentiality Level <span class="text-danger">*</span></h6>
          <p class="text-muted small mb-2" id="conf-help">What is the highest sensitivity of information the system will process, store, or transmit?</p>

          <select class="form-select cia-input" id="confidentialityLevel" name="confidentialityLevel" required>
            <option value="">Select confidentiality level...</option>
            <optgroup label="Non-National Interest (Protected)" id="conf-group-std">
              <option value="unclassified">Unclassified — No injury expected from disclosure</option>
              <option value="protected-a" id="conf-pa">Protected A — Limited injury (e.g., internal memos, routine performance feedback)</option>
              <option value="protected-b" selected id="conf-pb">Protected B — Serious injury (e.g., SIN, medical/tax/financial records, most PII)</option>
              <option value="protected-c" id="conf-pc">Protected C — Extremely grave injury (e.g., witness protection, informant IDs)</option>
            </optgroup>
            <optgroup label="National Interest (Classified)" id="conf-group-cls">
              <option value="confidential">Confidential — Limited injury to national interest</option>
              <option value="secret">Secret — Serious injury to national interest</option>
              <option value="top-secret">Top Secret — Exceptionally grave injury to national interest</option>
            </optgroup>
          </select>
          <div id="confHelp" class="form-text mt-1"></div>
        </div>
      </div>

      <!-- ── 2B: Integrity ── -->
      <div class="card mb-3 border-0 bg-light">
        <div class="card-body">
          <h6 class="fw-bold mb-1"><i class="bi bi-check2-square me-1"></i> Integrity Level <span class="text-danger">*</span></h6>
          <p class="text-muted small mb-2">What is the expected impact if data is modified, corrupted, or destroyed without authorization?</p>

          <select class="form-select cia-input" id="integrityLevel" name="integrityLevel" required>
            <option value="low">Low — Limited impact; minor data corruption tolerable with manual workarounds</option>
            <option value="medium" selected>Medium — Serious impact; data must be reliable, unauthorized changes significantly impact operations</option>
            <option value="high">High — Very serious impact; data accuracy is critical, corruption could endanger life/health/safety</option>
          </select>
        </div>
      </div>

      <!-- ── 2C: Availability ── -->
      <div class="card mb-3 border-0 bg-light">
        <div class="card-body">
          <h6 class="fw-bold mb-1"><i class="bi bi-clock-history me-1"></i> Availability Level <span class="text-danger">*</span></h6>
          <p class="text-muted small mb-2">What is the expected impact if the system is unavailable or disrupted?</p>

          <select class="form-select cia-input" id="availabilityLevel" name="availabilityLevel" required>
            <option value="low">Low — Extended outages (days) tolerable; alternative processes exist</option>
            <option value="medium" selected>Medium — Disruptions of hours could cause serious impact; system supports important operations</option>
            <option value="high">High — Even brief outages (minutes) cause grave impact; mission-critical or life/safety system</option>
          </select>
        </div>
      </div>

      <!-- ── 2D: High Value Asset ── -->
      <div class="card mb-3 border-0 bg-light" id="hva-card">
        <div class="card-body">
          <div class="form-check">
            <input class="form-check-input cia-input" type="checkbox" id="isHVA" name="isHVA" value="1">
            <label class="form-check-label" for="isHVA" id="hva-label">
              <strong><i class="bi bi-star me-1"></i> High Value Asset (HVA)</strong>
              <small class="d-block text-muted">Check if this system supports delivery of services at a national scale, is determined to be a significant solution handling sensitive information, or has been designated as a High Value Asset by your department. Adds the <strong>PBHVA overlay</strong> (137 additional controls).</small>
            </label>
          </div>
        </div>
      </div>

      <!-- ── Live Profile Preview ── (hidden from client — assessor-only) -->
      <div id="profilePreview" class="alert alert-secondary mb-3" style="display:none;">
        <div class="d-flex align-items-center mb-2">
          <i class="bi bi-cpu fs-5 me-2"></i>
          <div>
            <strong>Determined Security Profile:</strong>
            <span id="profileBadge" class="badge ms-2">—</span>
          </div>
        </div>
        <div id="profileName" class="fw-bold mb-1"></div>
        <div id="profileDesc" class="small mb-1"></div>
        <div id="profileControls" class="small text-muted"></div>
        <div id="profileTailoring" class="small mt-2" style="display:none;">
          <strong>Tailoring notes:</strong>
          <ul id="tailoringList" class="mb-0 mt-1 small"></ul>
        </div>
      </div>

      <hr class="my-3">

      <!-- ── 2E: PII Checklist ── -->
      <div class="mb-3" id="pii-section">
        <label class="form-label fw-bold" id="pii-heading">Personal Information (PII) Checklist</label>
        <p class="text-muted small mb-2">Does your system collect, process, store, or transmit any of the following? Check all that apply.</p>

        <div class="row g-2">
          <div class="col-md-6">
            <div class="form-check p-3 rounded border bg-white mb-1">
              <input class="form-check-input" type="checkbox" name="piiTypes" value="name-address" id="pii-name">
              <label class="form-check-label" for="pii-name">
                <strong>Name, address, or contact info</strong>
                <small class="d-block text-muted">Full name, home/work address, phone, email</small>
              </label>
            </div>
          </div>
          <div class="col-md-6" id="pii-sin-wrap">
            <div class="form-check p-3 rounded border bg-white mb-1">
              <input class="form-check-input" type="checkbox" name="piiTypes" value="sin" id="pii-sin">
              <label class="form-check-label" for="pii-sin" id="pii-sin-label">
                <strong>Social Insurance Number (SIN)</strong>
                <small class="d-block text-muted">SIN or business number</small>
              </label>
            </div>
          </div>
          <div class="col-md-6">
            <div class="form-check p-3 rounded border bg-white mb-1">
              <input class="form-check-input" type="checkbox" name="piiTypes" value="financial" id="pii-financial">
              <label class="form-check-label" for="pii-financial" id="pii-financial-label">
                <strong>Financial information</strong>
                <small class="d-block text-muted">Bank accounts, tax records, pay info, CRA data</small>
              </label>
            </div>
          </div>
          <div class="col-md-6">
            <div class="form-check p-3 rounded border bg-white mb-1">
              <input class="form-check-input" type="checkbox" name="piiTypes" value="health" id="pii-health">
              <label class="form-check-label" for="pii-health">
                <strong>Health / Medical records</strong>
                <small class="d-block text-muted">Medical history, disability, mental health info</small>
              </label>
            </div>
          </div>
          <div class="col-md-6">
            <div class="form-check p-3 rounded border bg-white mb-1">
              <input class="form-check-input" type="checkbox" name="piiTypes" value="biometric" id="pii-bio">
              <label class="form-check-label" for="pii-bio">
                <strong>Biometric data</strong>
                <small class="d-block text-muted">Fingerprints, facial recognition, voice prints</small>
              </label>
