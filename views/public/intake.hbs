  <!-- ═══════════════════════════════════════════════════════════ -->
  <!-- WIZARD & REGION ADAPTATION JAVASCRIPT                      -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <script>
  (function() {
    'use strict';

    // ── State ──────────────────────────────────────────────────
    let selectedRegions = [];
    let selectedFrameworks = new Set();

    const REGION_CONFIG = {
      'canada':          { label: 'Canada (Federal)', group: 'north-america', isCanada: true },
      'canada-finance':  { label: 'Canada (Financial)', group: 'north-america', isCanada: true, parent: 'canada' },
      'usa':             { label: 'United States', group: 'north-america' },
      'usa-defense':     { label: 'US (Defense)', group: 'north-america', parent: 'usa' },
      'usa-state':       { label: 'US (State/Local)', group: 'north-america', parent: 'usa' },
      'usa-finance':     { label: 'US (Financial)', group: 'north-america', parent: 'usa' },
      'eu':              { label: 'European Union', group: 'europe' },
      'eu-finance':      { label: 'EU (Financial)', group: 'europe', parent: 'eu' },
      'germany':         { label: 'Germany', group: 'europe' },
      'france':          { label: 'France', group: 'europe' },
      'uk':              { label: 'United Kingdom', group: 'europe' },
      'spain':           { label: 'Spain', group: 'europe' },
      'australia':       { label: 'Australia', group: 'asia-pacific' },
      'australia-finance': { label: 'Australia (Financial)', group: 'asia-pacific', parent: 'australia' },
      'global':          { label: 'Global', group: 'international' },
      'soc2':            { label: 'SOC 2', group: 'international' },
      'pci':             { label: 'PCI DSS', group: 'international' }
    };

    // ── DOM Elements ────────────────────────────────────────────
    const step1 = document.getElementById('wizardStep1');
    const step2 = document.getElementById('wizardStep2');
    const continueBtn = document.getElementById('wizardContinueBtn');
    const backBtn = document.getElementById('wizardBackBtn');
    const summaryText = document.getElementById('regionSummaryText');
    const fwList = document.getElementById('suggestedFrameworksList');
    const contextLabels = document.getElementById('regionContextLabels');
    const regionChecks = document.querySelectorAll('.region-check');

    // ── Continue: Step 1 → Step 2 ──────────────────────────────
    continueBtn.addEventListener('click', function() {
      selectedRegions = [];
      selectedFrameworks = new Set();
      regionChecks.forEach(function(cb) {
        if (cb.checked) {
          selectedRegions.push(cb.value);
          var fws = cb.dataset.frameworks || '';
          fws.split(',').forEach(function(f) { if (f) selectedFrameworks.add(f); });
        }
      });
      if (selectedRegions.length === 0) return;

      // Populate context bar badges
      var labels = selectedRegions.map(function(r) { return REGION_CONFIG[r] ? REGION_CONFIG[r].label : r; });
      contextLabels.innerHTML = labels.map(function(l) { return '<span class="badge bg-light text-primary border ms-1">' + l + '</span>'; }).join(' ');

      // Inject hidden field into form
      injectHiddenFields();

      // Adapt all form sections to the selected regions
      adaptFormToRegions();

      // Transition to Step 2
      step1.style.display = 'none';
      step2.style.display = 'block';
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });

    // ── Back: Step 2 → Step 1 ──────────────────────────────────
    backBtn.addEventListener('click', function() {
      step2.style.display = 'none';
      step1.style.display = 'block';
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });

    // ── Region Checkbox Handlers ───────────────────────────────
    regionChecks.forEach(function(cb) {
      cb.addEventListener('change', function() {
        // Show/hide sub-region checkboxes
        var subs = document.querySelectorAll('.region-sub[data-parent="' + this.value + '"]');
        subs.forEach(function(sub) {
          sub.style.display = cb.checked ? 'block' : 'none';
          if (!cb.checked) {
            var subCb = sub.querySelector('input');
            if (subCb) subCb.checked = false;
          }
        });
        updateSummary();
      });
    });

    // ── Summary Bar Update ─────────────────────────────────────
    function updateSummary() {
      var checked = document.querySelectorAll('.region-check:checked');
      var count = checked.length;
      var fws = new Set();
      checked.forEach(function(cb) {
        (cb.dataset.frameworks || '').split(',').forEach(function(f) { if (f) fws.add(f); });
      });

      if (count === 0) {
        summaryText.textContent = 'Select at least one region to continue';
        fwList.textContent = '';
        continueBtn.disabled = true;
      } else {
        summaryText.innerHTML = '<strong>' + count + '</strong> region' + (count > 1 ? 's' : '') +
          ' selected — <strong>' + fws.size + '</strong> framework' + (fws.size > 1 ? 's' : '') + ' will apply';
        fwList.innerHTML = Array.from(fws).map(function(f) {
          return '<span class="badge bg-primary bg-opacity-75 ms-1" style="font-size:0.65rem">' + f + '</span>';
        }).join(' ');
        continueBtn.disabled = false;
      }
    }

    // ── Hidden Field Injection ──────────────────────────────────
    function injectHiddenFields() {
      document.querySelectorAll('.wizard-hidden').forEach(function(el) { el.remove(); });
      var form = document.getElementById('intakeForm');
      if (!form) return;
      var inp = document.createElement('input');
      inp.type = 'hidden';
      inp.name = 'selectedRegions';
      inp.value = JSON.stringify(selectedRegions);
      inp.className = 'wizard-hidden';
      form.appendChild(inp);
    }

    // ═══════════════════════════════════════════════════════════
    //  FORM ADAPTATION ENGINE
    //  Transforms every section based on selected regions
    // ═══════════════════════════════════════════════════════════
    function adaptFormToRegions() {
      var hasCanada = selectedRegions.some(function(r) { return r === 'canada' || r === 'canada-finance'; });
      var hasNonCanada = selectedRegions.some(function(r) { return !(REGION_CONFIG[r] && REGION_CONFIG[r].isCanada); });
      var onlyCanada = hasCanada && !hasNonCanada;
      var noCanada = !hasCanada;
      var intl = !onlyCanada; // any non-Canada region present

      // ─── ALWAYS: suppress profile preview from client ────────
      var profileEl = document.getElementById('profilePreview');
      if (profileEl) profileEl.style.display = 'none';
      window._disableProfilePreview = true;

      // ─── SECTION 1: Project Information ──────────────────────
      var deptLabel = document.getElementById('lbl-department');
      var deptInput = document.getElementById('department');
      var branchLabel = document.getElementById('lbl-branch');
      var branchInput = document.getElementById('branch');
      var appInternal = document.getElementById('appType-internal');

      if (noCanada) {
        if (deptLabel) deptLabel.innerHTML = 'Organization <span class="text-danger">*</span>';
        if (deptInput) deptInput.placeholder = 'e.g. Acme Corporation, Ministry of Finance';
        if (branchLabel) branchLabel.textContent = 'Division / Business Unit';
        if (branchInput) branchInput.placeholder = 'e.g. IT Security Division';
        if (appInternal) appInternal.textContent = 'Internal Only (corporate network)';
      } else if (intl) {
        if (deptLabel) deptLabel.innerHTML = 'Department / Organization <span class="text-danger">*</span>';
        if (deptInput) deptInput.placeholder = 'e.g. Employment and Social Development Canada';
        if (appInternal) appInternal.textContent = 'Internal Only (government / corporate network)';
      }

      // ─── SECTION 2: Security Categorization ──────────────────
      var sec2Title = document.getElementById('sec2-title');
      var sec2Desc = document.getElementById('sec2-desc');
      var confHeading = document.getElementById('conf-heading');
      var confGroupStd = document.getElementById('conf-group-std');
      var confGroupCls = document.getElementById('conf-group-cls');
      var confPA = document.getElementById('conf-pa');
      var confPB = document.getElementById('conf-pb');
      var confPC = document.getElementById('conf-pc');
      var hvaLabel = document.getElementById('hva-label');
      var hvaCard = document.getElementById('hva-card');

      if (noCanada) {
        // Full international mode — no GoC references at all
        if (sec2Title) sec2Title.innerHTML = '<span class="section-number">2</span> Data Sensitivity & Impact Assessment';
        if (sec2Desc) sec2Desc.innerHTML = 'Assess the sensitivity of data handled by this system and the potential impact of a security breach. This determines which security controls apply.';
        if (confHeading) confHeading.innerHTML = '<i class="bi bi-shield-lock me-1"></i> Data Sensitivity Level <span class="text-danger">*</span>';
        if (confGroupStd) confGroupStd.label = 'Standard Classification';
        if (confGroupCls) confGroupCls.label = 'Classified / Restricted';
        if (confPA) confPA.textContent = 'Low Sensitivity — Limited impact from disclosure (e.g., internal memos)';
        if (confPB) confPB.textContent = 'Moderate Sensitivity — Serious impact from disclosure (e.g., PII, financial records)';
        if (confPC) confPC.textContent = 'High Sensitivity — Extremely grave impact from unauthorized disclosure';
        if (hvaLabel) hvaLabel.innerHTML = '<strong><i class="bi bi-star me-1"></i> Critical / High-Value System</strong><small class="d-block text-muted">Check if this system is critical infrastructure, supports essential or national-scale services, or processes highly sensitive data requiring enhanced security controls.</small>';
      } else if (intl) {
        // Mixed: keep GoC terms but add international context
        if (sec2Title) sec2Title.innerHTML = '<span class="section-number">2</span> Security Categorization & Impact Assessment';
        if (sec2Desc) sec2Desc.innerHTML = 'Categorize your system\'s data sensitivity and assess the impact of a security breach. For Canadian government systems, this aligns with TBS Appendix J.';
        if (hvaLabel) hvaLabel.innerHTML = '<strong><i class="bi bi-star me-1"></i> High Value Asset / Critical System</strong><small class="d-block text-muted">Check if this system is critical infrastructure, supports national-scale services, or has been designated as a high-value asset.</small>';
      }

      // ─── SECTION 2: PII Checklist ────────────────────────────
      var sinLabel = document.getElementById('pii-sin-label');
      var finLabel = document.getElementById('pii-financial-label');
      var immWrap = document.getElementById('pii-imm-wrap');
      var indigWrap = document.getElementById('pii-indig-wrap');
      var atipWrap = document.getElementById('atip-wrap');
      var atipLabel = document.getElementById('atip-label');
      var piaLabel = document.getElementById('pia-label');

      if (noCanada) {
        // Replace GoC-specific PII items
        if (sinLabel) sinLabel.innerHTML = '<strong>National ID / Tax ID / SSN</strong><small class="d-block text-muted">Social Security Number, Tax ID, National Insurance Number, etc.</small>';
        if (finLabel) finLabel.innerHTML = '<strong>Financial information</strong><small class="d-block text-muted">Bank accounts, tax records, payroll data</small>';
        // Hide GoC-only PII categories
        if (immWrap) immWrap.style.display = 'none';
        if (indigWrap) indigWrap.style.display = 'none';
        // Replace ATIP with FOI
        if (atipLabel) atipLabel.innerHTML = 'Is the data subject to <strong>Freedom of Information / Subject Access</strong> requests?';
        if (piaLabel) piaLabel.innerHTML = 'Has a <strong>Data Protection / Privacy Impact Assessment</strong> been completed?';
      } else if (intl) {
        // Mixed: broaden labels
        if (sinLabel) sinLabel.innerHTML = '<strong>SIN / National ID / Tax ID</strong><small class="d-block text-muted">Social Insurance Number, SSN, Tax Identification Number, etc.</small>';
        if (finLabel) finLabel.innerHTML = '<strong>Financial information</strong><small class="d-block text-muted">Bank accounts, tax records, payroll, CRA or equivalent data</small>';
        if (atipLabel) atipLabel.innerHTML = 'Is the data subject to <strong>ATIP / Freedom of Information</strong> requests?';
        if (piaLabel) piaLabel.innerHTML = 'Has a <strong>Privacy Impact Assessment (PIA / DPIA)</strong> been completed?';
      }

      // ─── SECTION 3: Hosting & Technology ─────────────────────
      var hostSSC = document.getElementById('host-ssc');
      var techSSCWrap = document.getElementById('tech-ssc-wrap');
      var techGCNetWrap = document.getElementById('tech-gcnet-wrap');
      var techCSEWrap = document.getElementById('tech-cse-wrap');
      var hostRegion = document.getElementById('hostingRegion');

      if (noCanada) {
        if (hostSSC) hostSSC.style.display = 'none';
        if (techSSCWrap) techSSCWrap.style.display = 'none';
        if (techGCNetWrap) techGCNetWrap.style.display = 'none';
        if (techCSEWrap) techCSEWrap.style.display = 'none';
      } else if (intl) {
        if (hostSSC) hostSSC.textContent = 'SSC / Government Data Centre (On-Premises)';
      }

      // Data residency dropdown — rebuild based on regions
      if (hostRegion) {
        var curVal = hostRegion.value;
        hostRegion.innerHTML = '<option value="">Select...</option>';
        if (hasCanada) hostRegion.add(new Option('Canada Only', 'canada-only'));
        var hasUSA = selectedRegions.indexOf('usa') !== -1;
        var hasEU = selectedRegions.some(function(r) { return ['eu','germany','france','spain'].indexOf(r) !== -1; });
        var hasUK = selectedRegions.indexOf('uk') !== -1;
        var hasAU = selectedRegions.indexOf('australia') !== -1;
        if (hasCanada && hasUSA) hostRegion.add(new Option('Canada Primary (US failover)', 'canada-primary'));
        if (hasUSA) hostRegion.add(new Option('United States', 'usa'));
        if (hasEU) hostRegion.add(new Option('EU / EEA', 'eu'));
        if (hasUK) hostRegion.add(new Option('United Kingdom', 'uk'));
        if (hasAU) hostRegion.add(new Option('Australia', 'australia'));
        hostRegion.add(new Option('Multi-Region', 'multi-region'));
        hostRegion.add(new Option('Global', 'global'));
        hostRegion.add(new Option('Unsure', 'unsure'));
        if (curVal) hostRegion.value = curVal;
        if (!hostRegion.value) {
          if (onlyCanada) hostRegion.value = 'canada-only';
          else if (selectedRegions.length === 1 && hasEU) hostRegion.value = 'eu';
          else if (selectedRegions.length === 1 && hasUSA) hostRegion.value = 'usa';
        }
