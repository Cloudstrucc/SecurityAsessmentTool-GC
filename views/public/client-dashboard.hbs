<div class="container py-4" style="max-width:960px">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h1 class="mb-1">My Dashboard</h1>
      <p class="text-muted mb-0">Welcome back, {{clientUser.name}}</p>
    </div>
    <a href="/intake" class="btn btn-primary"><i class="bi bi-plus-circle me-1"></i>New Intake</a>
  </div>

  <!-- ══ Assessments ══ -->
  {{#if assessments.length}}
  <div class="form-section">
    <div class="section-header">
      <h3 class="section-title">
        <span class="section-number"><i class="bi bi-shield-check"></i></span>
        My Assessments
      </h3>
    </div>
    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0">
        <thead>
          <tr>
            <th>Project</th>
            <th>Status</th>
            <th>Invite Code</th>
            <th>Created</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          {{#each assessments}}
          <tr>
            <td class="fw-semibold">{{this.project_name}}</td>
            <td>
              {{#if (eq this.status 'draft')}}<span class="badge bg-secondary">Draft</span>
              {{else if (eq this.status 'evidence-gathering')}}<span class="badge bg-warning text-dark">Evidence Gathering</span>
              {{else if (eq this.status 'submitted')}}<span class="badge bg-info">Submitted</span>
              {{else if (eq this.status 'audit')}}<span class="badge bg-primary">Under Audit</span>
              {{else if (eq this.status 'completed')}}<span class="badge bg-success">Completed</span>
              {{else}}<span class="badge bg-secondary">{{this.status}}</span>
              {{/if}}
            </td>
            <td><code class="small">{{this.invite_code}}</code></td>
            <td class="small text-muted">{{this.created_at}}</td>
            <td>
              {{#if (eq this.status 'evidence-gathering')}}
                <a href="/respond/{{this.invite_code}}" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil-square me-1"></i>Respond</a>
              {{else if (eq this.status 'submitted')}}
                <a href="/respond/{{this.invite_code}}" class="btn btn-sm btn-outline-secondary"><i class="bi bi-eye me-1"></i>View</a>
              {{else if (eq this.status 'audit')}}
                <a href="/respond/{{this.invite_code}}" class="btn btn-sm btn-outline-secondary"><i class="bi bi-eye me-1"></i>View</a>
              {{else if (eq this.status 'completed')}}
                <a href="/respond/{{this.invite_code}}" class="btn btn-sm btn-outline-success"><i class="bi bi-file-earmark-check me-1"></i>View Results</a>
              {{/if}}
              {{#if (eq this.ato_type 'iato')}}
                <a href="/respond/{{this.invite_code}}/poam" class="btn btn-sm btn-outline-warning ms-1"><i class="bi bi-list-check me-1"></i>POA&M</a>
              {{/if}}
            </td>
          </tr>
          {{/each}}
        </tbody>
      </table>
    </div>
  </div>
  {{/if}}

  <!-- ══ Intakes ══ -->
  <div class="form-section">
    <div class="section-header">
      <h3 class="section-title">
        <span class="section-number"><i class="bi bi-inbox"></i></span>
        My Intakes
      </h3>
    </div>
    {{#if intakes.length}}
    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0">
        <thead>
          <tr>
            <th>Reference</th>
            <th>Project</th>
            <th>Status</th>
            <th>Department</th>
            <th>Submitted</th>
          </tr>
        </thead>
        <tbody>
          {{#each intakes}}
          <tr>
            <td><code class="small">{{this.ref_code}}</code></td>
            <td class="fw-semibold">{{this.project_name}}</td>
            <td>
              {{#if (eq this.status 'pending')}}<span class="badge bg-warning text-dark">Pending Review</span>
              {{else if (eq this.status 'in-review')}}<span class="badge bg-info">In Review</span>
              {{else if (eq this.status 'accepted')}}<span class="badge bg-success">Accepted</span>
              {{else if (eq this.status 'declined')}}<span class="badge bg-danger">Declined</span>
              {{else}}<span class="badge bg-secondary">{{this.status}}</span>
              {{/if}}
            </td>
            <td class="small text-muted">{{this.department}}</td>
            <td class="small text-muted">{{this.created_at}}</td>
          </tr>
          {{/each}}
        </tbody>
      </table>
    </div>
    {{else}}
    <div class="text-center py-4 text-muted">
      <i class="bi bi-inbox" style="font-size:2rem;opacity:0.4"></i>
      <p class="mt-2">No intakes yet. <a href="/intake">Submit your first intake</a> to begin the security assessment process.</p>
    </div>
    {{/if}}
  </div>

  <!-- ══ Access Code ══ -->
  <div class="form-section">
    <div class="section-header">
      <h3 class="section-title">
        <span class="section-number"><i class="bi bi-key"></i></span>
        Enter Access Code
      </h3>
    </div>
    <p class="small text-muted mb-3">Received an invite code from your assessor? Enter it below to access the assessment.</p>
    <form action="/respond/access" method="POST" class="d-flex gap-2">
      <input type="text" name="code" class="form-control form-control-sm font-monospace" placeholder="e.g. A1B2C3D4" style="max-width:200px" required>
      <button type="submit" class="btn btn-sm btn-outline-primary"><i class="bi bi-arrow-right me-1"></i>Go</button>
    </form>
  </div>
</div>
