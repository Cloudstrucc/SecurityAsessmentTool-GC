<div class="container py-5" style="max-width:520px;">
  <div class="text-center mb-4">
    <div style="width:56px;height:56px;border-radius:14px;background:var(--gc-accent);display:flex;align-items:center;justify-content:center;margin:0 auto 1rem;">
      <i class="bi bi-box-arrow-in-right text-white" style="font-size:1.5rem;"></i>
    </div>
    <h3>Client Sign In</h3>
    <p class="text-muted">Sign in to submit or view your security assessment intakes.</p>
  </div>

  <div class="card">
    <div class="card-body p-4">

      {{#unless mfaStep}}
      <!-- Step 1: Email + Password -->
      <form method="POST" action="/client/login">
        <div class="mb-3">
          <label class="form-label" for="email">Email Address</label>
          <input type="email" class="form-control" id="email" name="email" required placeholder="your.name@agency.gc.ca" autofocus>
        </div>
        <div class="mb-4">
          <label class="form-label" for="password">Password</label>
          <input type="password" class="form-control" id="password" name="password" required>
        </div>
        <button type="submit" class="btn btn-primary w-100 py-2">
          <i class="bi bi-arrow-right me-2"></i>Continue
        </button>
      </form>
      {{else}}
      <!-- Step 2: MFA -->

      {{#if hasWebAuthn}}
      <!-- Passkey option (primary) -->
      <div id="passkeyLoginSection">
        <div class="text-center mb-3">
          <i class="bi bi-person-bounding-box" style="font-size:3rem;color:var(--gc-nav,#26374a)"></i>
        </div>
        <p class="text-center text-muted small mb-3">Approve with your passkey (Face ID, Touch ID, or Windows Hello).</p>
        <div id="passkeyError" class="alert alert-danger small py-2 d-none"></div>
        <button class="btn btn-primary w-100 py-2 mb-3" id="passkeyLoginBtn" data-user-id="{{userId}}">
          <i class="bi bi-person-bounding-box me-1"></i>Sign In with Passkey
        </button>
        <div class="text-center">
          <a href="#" class="small text-muted" id="switchToTotpBtn"><i class="bi bi-key me-1"></i>Use TOTP code instead</a>
        </div>
      </div>
      {{/if}}

      <!-- TOTP option -->
      <div id="totpLoginSection" {{#if hasWebAuthn}}class="d-none"{{/if}}>
        <div class="alert alert-info small mb-3">
          <i class="bi bi-shield-lock me-1"></i>Enter the 6-digit code from your authenticator app.
        </div>
        <form method="POST" action="/client/login/mfa">
          <input type="hidden" name="userId" value="{{userId}}">
          <div class="mb-4">
            <label class="form-label fw-bold">Authentication Code</label>
            <input type="text" class="form-control form-control-lg text-center" name="token"
              required maxlength="6" pattern="[0-9]{6}" placeholder="000000"
              style="letter-spacing:6px;font-family:'Courier New',monospace;font-weight:700;font-size:1.5rem;"
              autocomplete="one-time-code" inputmode="numeric" {{#unless hasWebAuthn}}autofocus{{/unless}}>
          </div>
          <button type="submit" class="btn btn-primary w-100 py-2">
            <i class="bi bi-check-circle me-2"></i>Verify & Sign In
          </button>
        </form>
        {{#if hasWebAuthn}}
        <div class="text-center mt-3">
          <a href="#" class="small text-muted" id="switchToPasskeyBtn"><i class="bi bi-person-bounding-box me-1"></i>Use passkey instead</a>
        </div>
        {{/if}}
      </div>

      {{/unless}}
    </div>
  </div>

  <div class="text-center mt-3">
    <span class="text-muted">Don't have an account?</span>
    <a href="/client/register">Register here</a>
  </div>
</div>

{{#if mfaStep}}
<script src="https://cdn.jsdelivr.net/npm/@simplewebauthn/browser@11/dist/bundle/index.umd.min.js"></script>
<script>
document.addEventListener('DOMContentLoaded', function() {
  // Toggle between passkey and TOTP
  const switchToTotp = document.getElementById('switchToTotpBtn');
  const switchToPasskey = document.getElementById('switchToPasskeyBtn');
  if (switchToTotp) {
    switchToTotp.addEventListener('click', function(e) {
      e.preventDefault();
      document.getElementById('passkeyLoginSection').classList.add('d-none');
      document.getElementById('totpLoginSection').classList.remove('d-none');
      document.querySelector('#totpLoginSection input[name="token"]')?.focus();
    });
  }
  if (switchToPasskey) {
    switchToPasskey.addEventListener('click', function(e) {
      e.preventDefault();
      document.getElementById('totpLoginSection').classList.add('d-none');
      document.getElementById('passkeyLoginSection').classList.remove('d-none');
    });
  }

  // Passkey login
  const passkeyBtn = document.getElementById('passkeyLoginBtn');
  if (passkeyBtn) {
    passkeyBtn.addEventListener('click', async function() {
      const userId = this.dataset.userId;
      const errEl = document.getElementById('passkeyError');
      this.disabled = true;
      this.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Waiting for biometric...';
      errEl.classList.add('d-none');

      try {
        const optResp = await fetch('/api/webauthn/auth-options', {
          method: 'POST', headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ userId: parseInt(userId) })
        });
        const opts = await optResp.json();
        if (opts.error) throw new Error(opts.error);

        const authResult = await SimpleWebAuthnBrowser.startAuthentication({ optionsJSON: opts });

        const verifyResp = await fetch('/api/webauthn/auth-verify', {
          method: 'POST', headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ ...authResult, _userId: userId })
        });
        const verifyData = await verifyResp.json();

        if (verifyData.success && verifyData.sig_token) {
          // Submit login form with sig_token
          const form = document.createElement('form');
          form.method = 'POST'; form.action = '/client/login/webauthn';
          const hidden = document.createElement('input');
          hidden.type = 'hidden'; hidden.name = '_sig_token'; hidden.value = verifyData.sig_token;
          form.appendChild(hidden);
          document.body.appendChild(form);
          form.submit();
          return;
        }
        throw new Error(verifyData.error || 'Verification failed');
      } catch (err) {
        errEl.textContent = err.name === 'NotAllowedError' ? 'Cancelled. Click to try again.' : err.message;
        errEl.classList.remove('d-none');
        this.disabled = false;
        this.innerHTML = '<i class="bi bi-person-bounding-box me-1"></i>Try Again';
      }
    });
  }
});
</script>
{{/if}}
